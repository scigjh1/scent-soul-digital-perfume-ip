# 推荐国内模型：deepseek / qwen / kimi / zhipu / custom / openai
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-key
LLM_MODEL=deepseek-chat
PORT=4177

